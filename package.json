{
  "name": "@aptos-labs/aptos-cli",
  "version": "1.2.0",
  "description": "Aptos CLI available from npmjs",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "aptos": "./dist/aptos.js"
  },
  "type": "module",
  "author": "aptoslabs.com",
  "keywords": [
    "aptos node cli",
    "aptos"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aptos-labs/aptos-cli"
  },
  "bugs": {
    "url": "https://github.com/aptos-labs/aptos-cli/issues"
  },
  "license": "Apache-2.0",
  "scripts": {
    "clean": "node -e \"const fs = require('fs'); fs.rmSync('dist', { recursive: true, force: true });\"",
    "build": "pnpm run clean && tsc",
    "dev": "pnpm run build && node ./dist/aptos.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check",
    "check:fix": "biome check --fix",
    "format": "biome format --fix"
  },
  "files": [
    "bin",
    "dist"
  ],
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^20.19.37",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
